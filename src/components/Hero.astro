---
import Default from "@astrojs/starlight/components/Hero.astro";
import InstallBlock from "./InstallBlock.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const isHomepage = Astro.url.pathname === base + "/" || Astro.url.pathname === base;
---

<div class="hero-gradient-wrap">
  {isHomepage ? (
    <div class="install-hero">
      <InstallBlock />
      <div class="scroll-indicator">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 9l6 6 6-6"></path>
        </svg>
      </div>
    </div>
  ) : (
    <Default><slot /></Default>
  )}
</div>

<style is:global>
  .hero-gradient-wrap {
    position: relative;
    overflow: hidden;
  }


  .hero-gradient-wrap::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle, rgba(255, 255, 255, 0.06) 1px, transparent 1px),
      radial-gradient(ellipse 60% 50% at 20% 60%, rgba(100, 60, 255, 0.08), transparent),
      radial-gradient(ellipse 50% 40% at 80% 30%, rgba(0, 180, 255, 0.06), transparent),
      radial-gradient(ellipse 40% 60% at 50% 80%, rgba(255, 255, 255, 0.03), transparent);
    background-size: 28px 28px, 100% 100%, 100% 100%, 100% 100%;
    pointer-events: none;
    z-index: 0;
  }

  .hero-gradient-wrap > * {
    position: relative;
    z-index: 1;
  }

  .install-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1rem 1rem 4rem;
    position: relative;
    /* Break out of sl-container max-width */
    width: 100vw;
    margin-left: calc(50% - 50vw);
    box-sizing: border-box;
  }

  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    color: var(--sl-color-gray-3);
    animation: bounce 2s ease infinite, fade-in 1s ease 1.5s both;
  }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
  }

  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* Desktop: full viewport */
  @media (min-width: 768px) {
    .install-hero {
      min-height: calc(100vh - 64px);
    }
  }

  /* Mobile: no full viewport, hide scroll indicator */
  @media (max-width: 767px) {
    .install-hero {
      padding: 2rem 1rem 1.5rem;
    }

    .scroll-indicator {
      display: none;
    }
  }
</style>
